{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm --filter api-types build && pnpm --filter frontend build",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/stripe/webhook/route.ts": { "maxDuration": 30 },
    "src/app/api/render/start/route.ts": { "maxDuration": 60 },
    "src/app/[locale]/auth/callback/route.ts": { "maxDuration": 10 }
  }
}
